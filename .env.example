# ─── Database ──────────────────────────────────────────────
DATABASE_URL="file:./data/master.db"

# ─── Server ────────────────────────────────────────────────
# Port to listen on. Use 80 if running directly without Caddy.
PORT=3000

# Hostname to log/display (cosmetic only)
HOST=masterserver.trackmania.com

# ─── Sessions ──────────────────────────────────────────────
# How long a session lives without activity (hours)
SESSION_TTL_HOURS=24

# ─── Servers ───────────────────────────────────────────────
# Mark a game server offline if no heartbeat for this many minutes
SERVER_TIMEOUT_MINUTES=5

# ─── Ladder ────────────────────────────────────────────────
# How often to rebuild the ladder snapshot (minutes)
LADDER_REBUILD_INTERVAL_MINUTES=10

# ─── Logging ───────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
